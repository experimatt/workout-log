<%= form_for(workout, html: {class: 'form-horizontal'}) do |f| %>
  <% if workout.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(workout.errors.count, "error") %> prohibited this workout from being saved:</h2>

      <ul>
      <% workout.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field form-group">
    <%= f.label :name, class: 'col-sm-2 control-label' %>
    <div class="col-sm-10">
      <%= f.text_field :name, class: 'form-control' %>
    </div>
  </div>

  <div class="field form-group">
    <%= f.label :description, class: 'col-sm-2 control-label' %>
    <div class="col-sm-10">
      <%= f.text_area :description, class: 'form-control' %>
    </div>
  </div>

  <div class="field form-group">
    <%= f.label :score_units, class: 'col-sm-2 control-label' %>
    <div class="col-sm-10">
      <%= f.text_area :score_units, class: 'form-control' %>
    </div>
  </div>

  <div class="actions form-group">
    <%= f.submit %>
  </div>
<% end %>
